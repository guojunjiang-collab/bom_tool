-- 图文档管理与附件改造 数据库迁移脚本
-- 执行前请备份数据库

-- 1. 创建图文档主表
CREATE TABLE IF NOT EXISTS documents (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    code VARCHAR(64) NOT NULL,
    name VARCHAR(255) NOT NULL,
    doc_type VARCHAR(64),
    version VARCHAR(32) DEFAULT 'V1.0',
    description TEXT,
    file_name VARCHAR(255),
    file_id UUID,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 图文档唯一约束：编号+版本
ALTER TABLE documents ADD CONSTRAINT uix_doc_code_version UNIQUE (code, version);

-- 2. 创建图文档独立附件表
CREATE TABLE IF NOT EXISTS document_attachments (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    document_id UUID NOT NULL REFERENCES documents(id) ON DELETE CASCADE,
    file_name VARCHAR(255),
    file_data BYTEA,
    file_size INTEGER,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- document_attachments 外键关联
ALTER TABLE documents ADD CONSTRAINT fk_doc_file
    FOREIGN KEY (file_id) REFERENCES document_attachments(id) ON DELETE SET NULL;

-- 3. 创建实体-图文档关联表
CREATE TABLE IF NOT EXISTS entity_documents (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    entity_type VARCHAR(32) NOT NULL,
    entity_id UUID NOT NULL,
    document_id UUID NOT NULL REFERENCES documents(id) ON DELETE RESTRICT,
    category VARCHAR(64),
    sort_order INTEGER DEFAULT 0,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
);

-- 4. 删除零件和部件表的旧附件字段
ALTER TABLE parts DROP COLUMN IF EXISTS source_file;
ALTER TABLE parts DROP COLUMN IF EXISTS source_file_id;
ALTER TABLE parts DROP COLUMN IF EXISTS drawing;
ALTER TABLE parts DROP COLUMN IF EXISTS drawing_id;
ALTER TABLE parts DROP COLUMN IF EXISTS stp;
ALTER TABLE parts DROP COLUMN IF EXISTS stp_id;
ALTER TABLE parts DROP COLUMN IF EXISTS pdf;
ALTER TABLE parts DROP COLUMN IF EXISTS pdf_id;

ALTER TABLE assemblies DROP COLUMN IF EXISTS source_file;
ALTER TABLE assemblies DROP COLUMN IF EXISTS source_file_id;
ALTER TABLE assemblies DROP COLUMN IF EXISTS drawing;
ALTER TABLE assemblies DROP COLUMN IF EXISTS drawing_id;
ALTER TABLE assemblies DROP COLUMN IF EXISTS stp;
ALTER TABLE assemblies DROP COLUMN IF EXISTS stp_id;
ALTER TABLE assemblies DROP COLUMN IF EXISTS pdf;
ALTER TABLE assemblies DROP COLUMN IF EXISTS pdf_id;

-- 5. 清理孤立的旧 attachments 数据
DELETE FROM attachments WHERE id NOT IN (
    SELECT source_file_id FROM parts WHERE source_file_id IS NOT NULL
    UNION
    SELECT drawing_id FROM parts WHERE drawing_id IS NOT NULL
    UNION
    SELECT stp_id FROM parts WHERE stp_id IS NOT NULL
    UNION
    SELECT pdf_id FROM parts WHERE pdf_id IS NOT NULL
    UNION
    SELECT source_file_id FROM assemblies WHERE source_file_id IS NOT NULL
    UNION
    SELECT drawing_id FROM assemblies WHERE drawing_id IS NOT NULL
    UNION
    SELECT stp_id FROM assemblies WHERE stp_id IS NOT NULL
    UNION
    SELECT pdf_id FROM assemblies WHERE pdf_id IS NOT NULL
);

-- 可选：如果不再需要旧 attachments 表（保留以便回滚）
-- DROP TABLE IF EXISTS attachments;
